{
  "name": "@budgeting/mobile",
  "private": true,
  "version": "0.1.0",
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "start:usb": "adb reverse tcp:8081 tcp:8081 && expo start --localhost --clear",
    "open:usb": "adb reverse tcp:8081 tcp:8081 && adb shell am force-stop host.exp.exponent && adb shell am start -a android.intent.action.VIEW -d exp://127.0.0.1:8081 host.exp.exponent",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "7.18.5",
    "@react-navigation/native": "7.3.5",
    "@tanstack/react-query": "5.101.2",
    "expo": "~57.0.4",
    "expo-haptics": "57.0.0",
    "expo-linear-gradient": "57.0.0",
    "expo-status-bar": "57.0.0",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "typescript": "6.0.3"
  }
}
